# FOMO Radio Environment Variables
# Copy this to .env and fill in your values

# OpenRouter API Key (for LLM script generation)
# Get yours at: https://openrouter.ai/keys
export OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Telegram Bot Token (for sending voice messages)
# Get yours from @BotFather on Telegram
export TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# Telegram Chat ID (your chat with the bot)
export TELEGRAM_CHAT_ID="your_chat_id_here"

# Report directory (where daily-summary.md files live)
export REPORT_DIR="/workspace/app-ideas/ideas"

# Arweave Wallet Path (JWK JSON file)
export ARWEAVE_WALLET_PATH="/root/.arweave/wallet.json"

# Arweave Gateway
export ARWEAVE_GATEWAY="https://arweave.net"
